PORT=8787
HOST=0.0.0.0
COOKIE_SECRET=dev-secret
SQLITE_PATH=dev.db
ADMIN_TOKEN=change-me
# OAuth (Google)
# Create credentials in Google Cloud Console (OAuth 2.0 Client ID -> Web application)
# Authorized redirect URI must include:
#   http://localhost:8787/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=23456789oihgfju4567uh.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOC345678-ASDF3G2H78H
# Public URLs used to build redirect URIs (set these in prod)
PUBLIC_BACKEND_BASE=http://localhost:8787
PUBLIC_APP_BASE=http://localhost:3000
# Use HOST=127.0.0.1 if you want localhost-only binding.
# For Postgres use:
# DATABASE_URL=postgres://user:pass@localhost:5432/dbname

# Frontend (.env in /apps/frontend/)
PUBLIC_API_BASE=https://your-backend-domain.com

# Backend (.env in /apps/backend/)  
FRONTEND_URL=https://your-frontend-domain.com
COOKIE_SECRET=your_long_random_secret
DATABASE_URL=postgresql://...
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...