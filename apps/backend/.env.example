# Backend environment (copy to .env)
#
#   cp .env.example .env
#
# Notes:
# - This file is safe to commit.
# - Never commit real secrets in .env.

# -----------------------------
# Runtime
# -----------------------------
NODE_ENV=development
PORT=1299
HOST=0.0.0.0
LOG_LEVEL=debug
PRETTY_LOGS=1

# -----------------------------
# Database
# -----------------------------
# Default is SQLite at ./dev.db if DATABASE_URL is not set.
# Customize SQLite path (relative to apps/backend/):
SQLITE_PATH=dev.db

# Use Postgres instead by setting DATABASE_URL (and optionally commenting SQLITE_PATH):
# DATABASE_URL=postgresql://username:password@localhost:5432/canihavesex_today

# -----------------------------
# Auth / cookies (required)
# -----------------------------
# Generate a long random string (>= 32 chars).
COOKIE_SECRET=CHANGE_ME__min_32_chars

# Google OAuth (required by backend startup)
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# -----------------------------
# URLs / CORS
# -----------------------------
# Required in production; in dev it's helpful for correct redirects.
FRONTEND_URL=http://localhost:3112
PUBLIC_BACKEND_BASE=http://localhost:1299
PUBLIC_APP_BASE=http://localhost:3112

# Production (your domains)
# FRONTEND_URL=https://canihavesex.today
# PUBLIC_BACKEND_BASE=https://api.canihavesex.today
# PUBLIC_APP_BASE=https://canihavesex.today


