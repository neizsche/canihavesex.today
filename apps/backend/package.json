    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.2",
    "google-auth-library": "^10.6.2",
    "lru-cache": "^11.3.6",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "pino-pretty": "^13.0.0",
