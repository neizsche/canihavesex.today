{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "migrate": "node dist/scripts/migrate.js",
    "migrate:dev": "tsx src/scripts/migrate.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "simulate:normal": "tsx src/scripts/simulateUser.ts",
    "seed:demo": "tsx src/scripts/seedDemo.ts",
    "reset:db": "RESET_DB_CONFIRM=yes tsx src/scripts/resetDb.ts && npm run seed:demo",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.0",
    "@fastify/formbody": "^8.0.1",
    "@fastify/static": "^9.1.3",
    "@sentry/node": "^10.62.0",
    "dodopayments": "^2.39.1",
    "fastify": "^5.0.0",
    "fastify-raw-body": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.2",
    "google-auth-library": "^10.6.2",
    "lru-cache": "^11.3.6",
    "pg": "^8.12.0",
    "resend": "^6.14.0",
    "standardwebhooks": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.7.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
