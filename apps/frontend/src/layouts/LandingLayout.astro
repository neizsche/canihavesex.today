---
const { title } = Astro.props;
import SpeedInsights from '@vercel/speed-insights/astro';
import { LandingHeader } from '../components/LandingHeader';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/700.css';
import '@fontsource/outfit/800.css';
import '../styles/globals.css';
import { SITE_TITLE, APP_DESCRIPTION, APP_KEYWORDS, BRAND, CONTACT_EMAIL } from '../lib/siteConfig';
---

<!doctype html>
<html lang="en" class="bg-white">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <!-- Primary Meta Tags -->
    <title>{SITE_TITLE}</title>
    <meta name="title" content={SITE_TITLE} />
    <meta name="description" content={APP_DESCRIPTION} />
    <meta name="keywords" content={APP_KEYWORDS} />
    <meta name="author" content={BRAND.PREFIX + BRAND.HIGHLIGHT + BRAND.SUFFIX} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={"https://" + BRAND.PREFIX + BRAND.HIGHLIGHT + BRAND.SUFFIX + "/"} />
    <meta property="og:title" content={SITE_TITLE} />
    <meta property="og:description" content={APP_DESCRIPTION} />
    <meta property="og:image" content={"https://" + BRAND.PREFIX + BRAND.HIGHLIGHT + BRAND.SUFFIX + "/logo.png"} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={"https://" + BRAND.PREFIX + BRAND.HIGHLIGHT + BRAND.SUFFIX + "/"} />
    <meta property="twitter:title" content={SITE_TITLE} />
    <meta property="twitter:description" content={APP_DESCRIPTION} />
    <meta property="twitter:image" content={"https://" + BRAND.PREFIX + BRAND.HIGHLIGHT + BRAND.SUFFIX + "/logo.png"} />

    <!-- Theme & Icons -->
    <meta name="theme-color" content="#ffffff" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="canonical" href={"https://" + BRAND.PREFIX + BRAND.HIGHLIGHT + BRAND.SUFFIX + "/"} />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body class="bg-white text-gray-900 font-sans flex flex-col min-h-screen">
    <!-- Header -->
    <LandingHeader client:load />

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="border-t border-gray-100 bg-white">
      <div class="mx-auto max-w-5xl px-6 py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6">
          <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs font-medium text-gray-500">
            <a href="/about" class="hover:text-gray-900 transition-colors">About</a>
            <a href="/privacy" class="hover:text-gray-900 transition-colors">Privacy</a>
            <a href="/terms" class="hover:text-gray-900 transition-colors">Terms</a>
            <a href={`mailto:${CONTACT_EMAIL}`} class="hover:text-gray-900 transition-colors">Contact</a>
          </div>
        </div>
      </div>
    </footer>
    <SpeedInsights />
  </body>
</html>