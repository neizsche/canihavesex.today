---
const { title } = Astro.props;
import SpeedInsights from '@vercel/speed-insights/astro';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '../styles/globals.css';
---

<!doctype html>
<html lang="en" class="bg-white">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} | can i have sex today` : 'can i have sex today'}</title>
    <meta name="theme-color" content="#ffffff" />
  </head>
  <body class="bg-white text-gray-900 font-sans">
    <!-- Header -->
    <header class="sticky top-0 z-50 border-b border-gray-100 bg-white/80 backdrop-blur-md transition-all">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
        <a href="/" class="text-base font-medium tracking-wide text-gray-900 hover:text-gray-600 transition-colors">
          can i have sex today
        </a>
        <a
          href="/auth"
          class="inline-flex items-center gap-2 px-4 py-2 bg-slate-700 text-white text-sm font-normal rounded hover:bg-slate-800"
        >
          Log in
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-gray-200 bg-white">
      <div class="mx-auto max-w-7xl px-6 py-6">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <div class="flex items-center gap-6 text-sm text-gray-600">
            <a href="/about" class="hover:text-gray-900">About</a>
            <a href="/privacy" class="hover:text-gray-900">Privacy</a>
            <a href="/terms" class="hover:text-gray-900">Terms</a>
            <a href="mailto:support@canihavesex.today" class="hover:text-gray-900">Contact</a>
          </div>
        </div>
      </div>
    </footer>
    <SpeedInsights />
  </body>
</html>