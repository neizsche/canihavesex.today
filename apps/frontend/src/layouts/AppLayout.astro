---
const { title, active } = Astro.props;
const showBranding = Astro.props.showBranding ?? true;
const showNav = Astro.props.showNav ?? true;
const maxWidthClass = Astro.props.maxWidthClass ?? 'max-w-md px-4 pt-6';
import { BottomNav } from '@/components/common/BottomNav';
import '../styles/globals.css';
import { SITE_TITLE, BRAND, APP_DESCRIPTION, APP_KEYWORDS } from '@/lib/siteConfig';

const mainPaddingBottom = showNav ? 'pb-28' : 'pb-6';
// If this layout is being used for app-adjacent pages, keep the brand link inside the app shell.
const brandHref = showNav === false ? '/app#/today' : '/';
---

<!doctype html>
<html lang="en" class="bg-background">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title ? `${title} | ${SITE_TITLE}` : SITE_TITLE}</title>
    <meta property="og:site_name" content={BRAND.PREFIX + BRAND.HIGHLIGHT + BRAND.SUFFIX} />
    <meta property="og:image" content="/assets/opengraph-image.png" />
    <meta name="description" content={APP_DESCRIPTION} />
    <meta property="og:description" content={APP_DESCRIPTION} />
    <meta name="keywords" content={APP_KEYWORDS} />
    <meta name="theme-color" content="#0b0b0f" />
    <meta name="apple-mobile-web-app-title" content="Cycle" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <script>
      (() => {
        try {
          // Theme logic — dark is the default; light is opt-in via Settings.
          const stored = localStorage.getItem('theme');
          const shouldDark = stored ? stored === 'dark' : true;
          document.documentElement.classList.toggle('dark', shouldDark);

          // Scaling logic - considers both width and height
          const updateScale = () => {
            const h = window.innerHeight;
            const w = window.innerWidth;
            let scale = 'medium';

            // Desktop/laptop: use large scale for premium, spacious feel
            if (w > 768) {
              scale = 'large';
            } else {
              // For narrow screens (actual mobile), use height-based scaling
              if (h < 720) scale = 'small';
              else if (h > 850) scale = 'large';
              else scale = 'medium';
            }

            document.documentElement.setAttribute('data-scale', scale);
          };
          updateScale();
          window.addEventListener('resize', updateScale);
        } catch {
          // ignore
        }
      })();
    </script>
    <script is:inline>
      // Capture the PWA install prompt as early as possible so it isn't lost
      // before React mounts. Consumed by the install affordance in Settings
      // (see src/lib/pwaInstall.ts and useInstallPrompt).
      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        window.__deferredInstallPrompt = e;
        window.dispatchEvent(new Event('pwa:installable'));
      });
      window.addEventListener('appinstalled', () => {
        window.__deferredInstallPrompt = null;
      });

      // Landing page (apex domain) links here with `?install=1` to kick off the
      // install. First-time users hit sign-in/onboarding first, so persist the
      // intent now — before any auth redirect can strip the query — and let
      // useInstallHandoff act on it once the app proper mounts.
      try {
        var installUrl = new URL(window.location.href);
        if (installUrl.searchParams.get('install') === '1') {
          sessionStorage.setItem('pwa-install-intent', '1');
          installUrl.searchParams.delete('install');
          window.history.replaceState({}, '', installUrl.toString());
        }
      } catch (e) {
        /* sessionStorage unavailable (private mode quirks) — ignore */
      }
    </script>
    <script type="module">
      import { registerSW } from 'virtual:pwa-register';

      if (import.meta.env.PROD) {
        registerSW({ immediate: true });
      }
    </script>
  </head>
  <body class="bg-background text-foreground">
    {
      showBranding ? (
        <header class="sticky top-0 z-50 bg-background/90 backdrop-blur supports-[backdrop-filter]:bg-background/60">
          <div class={`mx-auto flex ${maxWidthClass} items-center justify-center px-4 pt-8 pb-4`}>
            <a
              href={brandHref}
              class="text-[22px] font-bold tracking-tight text-foreground select-none"
            >
              {BRAND.PREFIX}
              <span class="text-rose-500 font-extrabold italic mx-[1px]">{BRAND.HIGHLIGHT}</span>
              {BRAND.SUFFIX}
            </a>
          </div>
        </header>
      ) : null
    }

    <main class={`mx-auto min-h-dvh ${maxWidthClass} ${mainPaddingBottom}`}>
      <slot />
    </main>

    {showNav ? <BottomNav active={active} /> : null}
  </body>
</html>
