---
import AppLayout from '../layouts/AppLayout.astro';
---

<AppLayout title="Not found" active="today">
  <div class="space-y-4">
    <header class="space-y-1">
      <div class="text-sm text-muted-foreground">Not found</div>
      <h1 class="text-2xl font-semibold tracking-tight">This page doesn’t exist</h1>
      <p class="text-sm text-muted-foreground">Go back to Today.</p>
    </header>

    <div class="rounded-xl border bg-card p-4">
      <a class="text-sm font-medium underline underline-offset-4" href="/">Return to Today</a>
    </div>
  </div>
</AppLayout>
