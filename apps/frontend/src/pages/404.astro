---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout title="404 — Page Not Found">
  <section class="px-6 pt-32 pb-24 md:pt-48 md:pb-32 text-center max-w-4xl mx-auto">
    <h1 class="text-5xl md:text-8xl font-bold tracking-tight text-slate-950 mb-8 leading-[1.05] bg-clip-text text-transparent bg-gradient-to-b from-slate-950 to-slate-700">
      404
    </h1>
    <p class="text-xl md:text-2xl text-slate-600 mb-8 font-medium tracking-tight">
      This page doesn’t exist.
    </p>
    <p class="text-lg md:text-xl text-gray-500 mb-12 font-normal leading-relaxed">
      Sorry, we couldn’t find the page you’re looking for.
    </p>

    <div class="flex justify-center">
      <a
        href="/"
        class="inline-flex items-center justify-center h-12 px-8 text-base font-medium rounded-full bg-stone-900 text-white hover:bg-stone-800 transition-all shadow-sm hover:shadow-md"
      >
        Go back home
      </a>
    </div>
  </section>
</LandingLayout>
