---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout title="Terms">
  <div class="max-w-4xl mx-auto space-y-8">
    <header class="space-y-4 text-center">
      <h1 class="text-3xl font-semibold tracking-tight">Terms of use</h1>
      <p class="text-lg text-muted-foreground">Short terms for safe, informed use.</p>
    </header>

    <div class="rounded-xl border bg-card p-6">
      <div class="space-y-4 text-muted-foreground">
        <div>Informational only. Not a substitute for medical advice.</div>
        <div>Use at your own discretion.</div>
      </div>
    </div>
  </div>
</LandingLayout>