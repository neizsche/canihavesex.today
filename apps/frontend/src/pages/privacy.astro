---
import LandingLayout from '../layouts/LandingLayout.astro';
---

<LandingLayout title="Privacy">
  <div class="max-w-4xl mx-auto space-y-8">
    <header class="space-y-4 text-center">
      <h1 class="text-3xl font-semibold tracking-tight">Privacy</h1>
      <p class="text-lg text-muted-foreground">Plain-language overview of what we store and what we don't.</p>
    </header>

    <div class="rounded-xl border bg-card p-6">
      <div class="space-y-4 text-muted-foreground">
        <div>No analytics, no third-party sharing.</div>
        <div>Only stores cycle logs and authentication needed to run the app.</div>
        <div>"Delete All Data" is available in Settings.</div>
        <div>No ads, no profiling.</div>
      </div>
    </div>
  </div>
</LandingLayout>