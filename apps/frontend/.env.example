# Frontend Environment Configuration
# Copy this file to .env and customize for your deployment

# Backend API URL (optional - defaults to https://api.canihavesex.today)
PUBLIC_BACKEND_BASE=https://api.canihavesex.today

# Development mode (set to 'true' to enable development features)
PUBLIC_DEV_MODE=false

# Fallback mode (set to 'true' to show demo data when backend is unavailable)
PUBLIC_FALLBACK_MODE=false

# Google Analytics (optional)
# PUBLIC_GA_TRACKING_ID=your_google_analytics_id

# App configuration
PUBLIC_APP_NAME="Can I Have Sex Today"
PUBLIC_APP_BASE=https://canihavesex.today


# Clerk Authentication (get these from https://dashboard.clerk.com)
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here