# =====================================================================
# SHARED SECRETS (required for both dev and prod)
# =====================================================================
# Copy this file to `.env` and fill in your actual values.
# Never commit the `.env` file to git.

# Secrets
COOKIE_SECRET=CHANGE_ME__min_32_chars
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME


# =====================================================================
# FEATURE FLAGS
# =====================================================================
# PUBLIC_IS_NOT_OPENCORE (default: true)
# Set to 'false' to build open-core version without premium features
# Premium features include: mode switcher, Track Symptoms, premium upsells
PUBLIC_IS_NOT_OPENCORE=true
PUBLIC_IS_PREMIUM=false


# =====================================================================
# ENVIRONMENT-SPECIFIC CONFIGURATION
# =====================================================================
# Development settings: see .env.development
# Production settings: see .env.production
#
# The app automatically loads the correct file based on NODE_ENV:
# - NODE_ENV=development → loads .env.development
# - NODE_ENV=production → loads .env.production
#
# Your local `.env` file can override any setting from those files.
