
# IMPORTANT:
# - Do not commit your real `.env` file.
# - `PUBLIC_*` variables are exposed to the frontend bundle.

COOKIE_SECRET=CHANGE_ME__min_32_chars
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME
# ADMIN_TOKEN=CHANGE_ME


# =====================================================================
# DEV (enabled)
# =====================================================================
NODE_ENV=development
FRONTEND_PORT=3112
FRONTEND_PREVIEW_PORT=3112
ADMIN_FRONTEND_PORT=3001
ADMIN_FRONTEND_PREVIEW_PORT=3001
BACKEND_PORT=1299
BACKEND_HOST=0.0.0.0
PUBLIC_APP_BASE=http://localhost:3112
PUBLIC_BACKEND_BASE=http://localhost:1299
FRONTEND_URL=http://localhost:3112
LOG_LEVEL=debug
PRETTY_LOGS=1
SQLITE_PATH=dev.db
# DATABASE_URL=postgresql://username:password@localhost:5432/canihavesex_today



# =====================================================================
# PRODUCTION (commented — uncomment this whole block to switch)
# =====================================================================
