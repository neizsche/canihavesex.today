# Google OAuth. Leave BLANK to use email + password only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
COOKIE_SECRET=CHANGE_ME__run_openssl_rand_hex_32
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/canihavesex
# Time (ms) to wait for a DB connection before erroring. Default is 2000; bump
# it for remote poolers like Supabase ap-south-1 that are slow to hand one out.
DB_CONNECTION_TIMEOUT=20000
NODE_ENV=development
PUBLIC_APP_BASE=http://localhost:3112
FRONTEND_URL=http://localhost:3112
# Leave empty for same-origin (single image) / dev proxy:
# PUBLIC_BACKEND_BASE=

# Sentry DSN for error tracking (Cloud/SaaS). Leave empty to disable.
# SENTRY_DSN=

# Email + password sign-in. Enabled automatically in development; in production
# (NODE_ENV=production) it's off until you set this to true.
# ENABLE_PASSWORD_AUTH=true

# Set to true to offer a shared, pre-seeded demo account on the sign-in screen.
# Run `npm run seed:demo` (in apps/backend) once to populate it. Off by default.
# ENABLE_DEMO_ACCOUNT=false

# Secret for POST /api/admin/reseed-demo, which rebuilds the demo account to a
# clean state. Point a scheduler (e.g. Cloud Scheduler) at that endpoint with
# header `x-admin-secret: <this value>` to keep the demo fresh. The endpoint is
# disabled (404) unless both ENABLE_DEMO_ACCOUNT=true and this are set.
# DEMO_RESEED_SECRET=

# --- Self-host edition ------------------------------------------------------
# Set this on a self-hosted deployment. It HARD-disables billing, payments and
# purchase emails no matter what else is configured below — even if you set
# BILLING_ENABLED or the DODO_*/RESEND_* keys, none of it runs. The self-hosted
# app is free, forever, with no paywall. (Cloud leaves this unset.)
# SELF_HOST=true

# --- Billing / subscriptions (CLOUD ONLY) -----------------------------------
# Turn on the paywall. Leave unset for self-hosting → the app is fully unlocked
# and none of the billing code runs. When true, cloud users get a free trial
# from signup, then must subscribe (Yearly or Lifetime) to keep using the app.
# Ignored when SELF_HOST=true.
# BILLING_ENABLED=true
# Free-trial length in days from signup (default 14). Set 0 for no trial —
# new users are blocked until they pay.
# BILLING_TRIAL_DAYS=14
# Payment provider credentials (Dodo Payments). The provider is only built when
# ALL of these are set; otherwise billing reports "unavailable". Secrets — keep
# them here in the gitignored .env, never commit them.
# DODO_API_KEY=
# DODO_WEBHOOK_SECRET=
# DODO_ENVIRONMENT=test_mode        # or live_mode
# DODO_PRODUCT_ID_YEARLY=
# DODO_PRODUCT_ID_LIFETIME=

# --- Email verification (CLOUD ONLY) ----------------------------------------
# REQUIRE_EMAIL_VERIFICATION=false
# RESEND_API_KEY=
# EMAIL_FROM=canihavesex.today <noreply@yourdomain.com>

# Note: for Docker self-hosting, COOKIE_SECRET and DATABASE_URL come from
# docker-compose, not this file. See SELF_HOSTING.md.
